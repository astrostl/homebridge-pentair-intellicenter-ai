# Compiled pentameter sidecar binaries (built per-platform by `make build`).
# For releases these get bundled into the npm tarball; for dev they're rebuilt.
/pentameter/

# Node (the shim has zero deps, but keep this just in case)
node_modules/
npm-debug.log*

# Homebridge runtime state used for local Docker dev — never commit secrets/state
homebridge-config/*
!homebridge-config/config.template.json

# Local, machine-specific troubleshooting notes (prod IPs, bridge layout, etc.).
# Never commit — it documents the maintainer's private setup.
/LOCAL.md

# OS
.DS_Store
